# soc backend env (bare systemd install). Copy to /etc/soc/soc.env.
LOKI_URL=http://CENTRAL_VM_IP:3100
INGRESS_SELECTOR={app="ingress-nginx"}
LLM_URL=http://192.0.2.20:11434
LLM_MODEL=gemma3:4b
WINDOW=5m
POLL_INTERVAL=30
DB_PATH=/opt/soc/backend/soc.db
# Dashboard auth (set both in prod):
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Ban orchestrator (empty = ban buttons off):
BLOCKLIST_API_URL=http://CENTRAL_VM_IP:8080
BLOCKLIST_API_TOKEN=changeme
