# soc backend env (bare systemd install). Copy to /etc/soc/soc.env.
LOKI_URL=http://CENTRAL_VM_IP:3100
INGRESS_SELECTOR={app="ingress-nginx"}
LLM_URL=http://192.0.2.20:11434
LLM_MODEL=gemma3:4b
WINDOW=5m
POLL_INTERVAL=30
DB_PATH=/opt/soc/backend/soc.db
# Dashboard auth — REQUIRED. If both are empty the dashboard FAILS CLOSED (503 on
# every page/API) — it controls bans/settings/backends and is never open by default.
# Generate a password:  openssl rand -base64 24
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
# To run WITHOUT auth on a trusted/isolated host, set this instead of the creds above:
# SOC_DEV_NO_AUTH=1
# Ban orchestrator (empty = ban buttons off):
BLOCKLIST_API_URL=http://CENTRAL_VM_IP:8080
BLOCKLIST_API_TOKEN=changeme
