# ─────────────────────────────────────────────────────────────────────────────
# soc — unified environment. Copy to deploy/.env and edit. Used by docker compose
# (all profiles read it) and as the reference for the per-component systemd env
# files. Everything is overridable here so no config file needs hand-editing.
# ─────────────────────────────────────────────────────────────────────────────

# Which compose services to start (comma-separated). Leave unset and pass
# --profile flags instead if you prefer.
#   central VM : loki,soc,blocklist          nginx VM : promtail
COMPOSE_PROFILES=loki,soc,blocklist

# One knob for the ban topology — picks sane STORE/ENFORCE defaults (explicit STORE/
# ENFORCE/BAN_TARGETS below still override it). Leave empty for manual control.
#   k8s        → configmap store + ingress-nginx enforcement
#   cloudflare → sqlite store + Cloudflare API enforcement (set CF_API_TOKEN)
#   nginx      → sqlite store + plain-nginx enforcement via enrolled agents
# DEPLOY_MODE=

# ── Loki (central log store) ─────────────────────────────────────────────────
LOKI_PORT=3100
LOKI_DATA_DIR=/var/lib/loki
LOKI_RETENTION=336h          # 14d
LOKI_LOG_LEVEL=warn

# ── Promtail (on each nginx VM) ──────────────────────────────────────────────
# Point at the central Loki. From another host use its address, NOT localhost.
LOKI_PUSH_URL=http://CENTRAL_VM_IP:3100/loki/api/v1/push
VM_LABEL=nginx-1                       # unique per nginx host
NGINX_LOG_APP=ingress-nginx            # MUST match soc INGRESS_SELECTOR below
NGINX_LOG_DIR=/var/log/nginx           # host dir mounted into the promtail container
NGINX_ACCESS_LOG=/var/log/nginx/access.json.log
NGINX_ERROR_LOG=/var/log/nginx/error.log
PROMTAIL_PORT=9080
# Log format: promtail.yml = soc_json (recommended, see deploy/nginx/soc-logging.conf)
# promtail-combined.yml = parse the STOCK nginx `combined` log (no nginx change;
# set NGINX_ACCESS_LOG=/var/log/nginx/access.log).
PROMTAIL_CONFIG=promtail.yml
# Optional Loki auth (leave empty to disable):
LOKI_TENANT_ID=
LOKI_BASIC_AUTH_USER=
LOKI_BASIC_AUTH_PASS=

# ── soc backend ──────────────────────────────────────────────────────────────
SOC_PORT=8077
LOKI_URL=http://loki:3100               # compose service name; on bare VM use the IP
INGRESS_SELECTOR={app="ingress-nginx"}  # keep in sync with NGINX_LOG_APP
LLM_URL=http://192.0.2.20:11434
LLM_MODEL=gemma3:4b
WINDOW=5m
POLL_INTERVAL=30
# Dashboard auth (set both in prod; empty = no auth, dev only):
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Link to the ban orchestrator (empty = ban buttons disabled):
BLOCKLIST_API_URL=http://blocklist:8080
BLOCKLIST_API_TOKEN=changeme

# ── blocklist-api (ban orchestrator) ─────────────────────────────────────────
BLOCKLIST_PORT=8080
BLOCKLIST_TOKEN=changeme                # ADMIN token; must equal BLOCKLIST_API_TOKEN above
# Node enrollment (Datadog-style). ENROLL_SECRET is the shared key agents present to
# self-register; each then gets its own per-node token (revocable in «Ноды»). PUBLIC_URL
# is the address VMs reach this API at — used to build the install one-liner the
# dashboard shows. Leave ENROLL_SECRET empty to disable enrollment.
ENROLL_SECRET=changeme-enroll
PUBLIC_URL=http://CENTRAL_VM_IP:8080
NODE_OFFLINE_AFTER=120                   # seconds without heartbeat → node shown offline
# Hybrid config: when set to env/1/true the dashboard «Настройки» tab is READ-ONLY and
# every value below comes from ENV only (declarative / GitOps). Default: GUI can override.
# CONFIG_LOCK=
# WHERE denylist STATE is stored:  configmap (k8s) | file | sqlite (VM/Docker)
STORE=file
STORE_DIR=/data/denylist                # for STORE=file
STORE_SQLITE=/data/denylist.db          # for STORE=sqlite
# WHERE bans are ENFORCED.
#   Simple form (comma list of types): ingress-cm | nginx-file | cloudflare | noop
#     default follows STORE (configmap→ingress-cm, file/sqlite→noop).
# ENFORCE=noop
#   Grouped form (overrides ENFORCE): name targets, then route bans by group.
#   A block with no group → BAN_GROUP_DEFAULT; unknown group → ALL targets.
# BAN_TARGETS=[{"id":"edge-cf","type":"cloudflare","mode":"ip-list"},{"id":"web1","type":"nginx-file"},{"id":"k8s","type":"ingress-cm"}]
# BAN_GROUPS={"default":["edge-cf"],"origins":["web1"],"all":["edge-cf","web1","k8s"]}
# BAN_GROUP_DEFAULT=default
# k8s-only (STORE=configmap / ENFORCE=ingress-cm):
# CONTROLLER_NS=ingress-nginx
# CONTROLLER_CM=ingress-nginx-controller
# DENYLIST_NS=soc
# DENYLIST_CM=soc-denylist
# ── soc-nginx-agent (on each nginx VM, target type=nginx-file) ────────────────
# Easiest install: the «+ Добавить ноду» one-liner from the dashboard (it sets all
# of this for you). These vars are for manual/compose installs. The agent self-enrolls
# with ENROLL_SECRET and gets its own token → no admin token on the VM. Include the
# server file ONCE inside your server{} block: include /etc/nginx/soc-deny-server.conf;
# ENROLL_SECRET=changeme-enroll         # same value as the central ENROLL_SECRET
# NODE_ID=web1                          # default: hostname; also its TARGET_ID
# GROUP=                                # ban group this node joins (auto-promoted target)
TARGET_ID=web1                          # target id to pull (default: NODE_ID)
STATE_FILE=/var/lib/soc-agent/state.json
HTTP_FILE=/etc/nginx/conf.d/soc-deny.conf
SERVER_FILE=/etc/nginx/soc-deny-server.conf
TEST_CMD=nginx -t                       # config test gate before reload (rollback if it fails)
RELOAD_CMD=nginx -s reload
# NGINX_DIR / NGINX_CONF_DIR are only for the compose `agent` profile mounts.
# NGINX_DIR=/etc/nginx
# NGINX_CONF_DIR=/etc/nginx/conf.d

# Cloudflare (for type=cloudflare targets). You set only the TOKEN — the IP List
# and WAF rule are auto-created on the first ban; use the dashboard «Проверить»
# button (Autoban tab) to verify token/list/rule. Zone/account auto-discovered.
# CF_API_TOKEN=
# CF_MODE=ip-list                # ip-list | access-rules
# CF_ZONE_NAME=example.com       # or CF_ZONE_ID=...  (skip if token has one zone)
# CF_LIST_NAME=soc_blocklist
# CF_RULE_DESC=soc blocklist
