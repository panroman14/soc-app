# soc-nginx-agent env (bare systemd install). Copy to /etc/soc/agent.env.
# The install one-liner / inventory script write this for you — edit only for
# manual installs. Keep mode 0600 (it holds ENROLL_SECRET until the node token
# is minted into /var/lib/soc-agent/state.json).
BLOCKLIST_API_URL=http://CENTRAL_VM_IP:8080

# Enrollment (recommended): one shared key; the agent self-registers and gets its
# own per-node token. Leave ENROLL_SECRET empty to use the legacy admin token
# (BLOCKLIST_TOKEN) instead — then there is no heartbeat / «Ноды» visibility.
ENROLL_SECRET=changeme-enroll  # MUST equal the central blocklist-api ENROLL_SECRET
#BLOCKLIST_TOKEN=             # legacy fallback only (admin token)

NODE_ID=web1                   # this node's id (default: hostname); also its TARGET_ID
GROUP=                         # desired ban group (informational at enroll)
TARGET_ID=web1                 # target id to pull (default: NODE_ID)
STATE_FILE=/var/lib/soc-agent/state.json
HTTP_FILE=/etc/nginx/conf.d/soc-deny.conf
SERVER_FILE=/etc/nginx/soc-deny-server.conf
TEST_CMD=nginx -t
RELOAD_CMD=nginx -s reload
POLL_INTERVAL=30
