# soc Promtail env (bare systemd install). Copy to /etc/soc/promtail.env.
# Only the vars promtail.yml actually reads.
LOKI_PUSH_URL=http://CENTRAL_VM_IP:3100/loki/api/v1/push
VM_LABEL=nginx-1
NGINX_LOG_APP=ingress-nginx
# soc_json format (recommended). To ingest the STOCK nginx `combined` log instead,
# copy promtail-combined.yml to /etc/soc/promtail.yml and set the access log to the
# plain file (e.g. /var/log/nginx/access.log) — no nginx change needed.
NGINX_ACCESS_LOG=/var/log/nginx/access.json.log
NGINX_ERROR_LOG=/var/log/nginx/error.log
PROMTAIL_PORT=9080
POSITIONS_FILE=/var/lib/promtail/positions.yaml
# Optional Loki auth:
LOKI_TENANT_ID=
LOKI_BASIC_AUTH_USER=
LOKI_BASIC_AUTH_PASS=
